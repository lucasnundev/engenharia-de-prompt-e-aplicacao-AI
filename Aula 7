        "import math\n",
        "\n",
        "#Numero primo\n",
        "def eh_primo(n):\n",
        "  if n < 2:\n",
        "    return False\n",
        "  if n == 2:\n",
        "    return True\n",
        "  if n % 2 == 0: # Otimização: Elimina números pares maiores que 2\n",
        "    return False\n",
        "  # Verifica divisores ímpares a partir de 3 até a raiz quadrada de n\n",
        "  for i in range(3, int(n**0.5) + 1, 2):\n",
        "    if n % i == 0:\n",
        "      return False\n",
        "  return True"
      ],
