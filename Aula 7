        "def somar(a, b):\n",
        "  return a + b\n",
        "\n",
        "def subtrair(a, b):\n",
        "  return a - b\n",
        "\n",
        "def multiplicar(a, b):\n",
        "  return a * b\n",
        "\n",
        "def dividir(a, b):\n",
        "  if b == 0:\n",
        "    return \"Erro: Divisão por zero não é permitida!\"\n",
        "  return a / b\n",
        "  # Exemplos de uso\n",
        "print(f\"5 + 3 = {somar(5, 3)}\")\n",
        "print(f\"10 - 4 = {subtrair(10, 4)}\")\n",
        "print(f\"6 * 7 = {multiplicar(6, 7)}\")\n",
        "print(f\"20 / 5 = {dividir(20, 5)}\")\n",
        "print(f\"10 / 0 = {dividir(10, 0)}\") # Teste de divisão por zero"
      ],
